# Coldbones Backend Configuration
# Copy this to .env and adjust values

# LM Studio OpenAI-compatible API endpoint
# Exposed via Tailscale Funnel on the GPU PC — run: tailscale funnel --bg 1234
# For local-only dev (GPU PC on same tailnet): http://100.126.27.56:1234/v1
LM_STUDIO_URL=https://seratonin.tail40ae2c.ts.net/v1

# Model name as loaded in LM Studio
LM_STUDIO_MODEL=qwen/qwen3.5-35b-a3b

# Maximum file size in bytes (20 MB)
MAX_FILE_SIZE=20971520

# Server port
PORT=8000
