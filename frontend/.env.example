# ColdBones frontend — local dev environment
# Copy to .env and fill in values

# Leave empty when running against the local FastAPI dev server on :8000
# Set to your CloudFront URL or https://app.omlahiri.com for production testing
VITE_API_BASE_URL=

# AWS Cognito — get values from: cdk deploy outputs or scripts/cdk-outputs.json
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=
