# Coldbones desktop worker — copy to .env and fill in values
# Never commit the filled-in .env to git.

# ── AWS (use a scoped IAM user — see worker/SETUP.md) ─────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── Queue & storage (copy from scripts/cdk-outputs.json) ─────────────────────
# Example lookup:
#   jq -r '.ColdbonesQueue.QueueUrl, .ColdbonesStorage.UploadBucketName, .ColdbonesStorage.JobsTableName' \
#     ../scripts/cdk-outputs.json
ANALYZE_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<account-id>/coldbones-analysis
UPLOAD_BUCKET=coldbonesstorage-uploadbucket<suffix>
JOBS_TABLE=coldbones-jobs

# ── Local LM Studio ──────────────────────────────────────────────────────────
LM_STUDIO_URL=http://localhost:1234
LM_STUDIO_API_KEY=lm-studio
MODEL_NAME=qwen/qwen3.5-35b-a3b

# ── Limits ────────────────────────────────────────────────────────────────────
MAX_INFERENCE_TOKENS=8192
MAX_PDF_PAGES=20
